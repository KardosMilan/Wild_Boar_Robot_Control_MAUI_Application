<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VadkanRobotClient.MainPage"
             xmlns:conv="clr-namespace:VadkanRobotClient.Converters">
    <ContentPage.Resources>
        <conv:BatteryToProgressbar x:Key="BatteryConverter"/>
        <conv:BatteryToColor x:Key="BatteryColorConverter"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto"
          ColumnDefinitions="*">

        <!-- SETTINGS BAR -->
        <Frame Grid.Row="0"
               Margin="10,5,10,0"
               Padding="5"
               CornerRadius="8"
               HasShadow="True"
               BackgroundColor="#1E1E1E">

            <Grid ColumnDefinitions="Auto,Auto">

                <!-- Icon -->
                <Label Text="⚙"
                       FontSize="20"
                       VerticalOptions="Center"/>

                <!-- Settings button-->
                <Label Grid.Column="1"
                       Text="Robot Settings"
                       FontSize="16"
                       VerticalOptions="Center"
                       TextColor="White">

                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenSettingsCommand}" />
                    </Label.GestureRecognizers>

                </Label>

            </Grid>
        </Frame>

        <!-- Canvas-->
        <Frame Grid.Row="1"
               Margin="10"
               Padding="2"
               CornerRadius="10"
               HasShadow="True"
               BackgroundColor="#228B22">

            <Grid x:Name="CanvasGrid">
                <GraphicsView x:Name="graphicsView"
                  HorizontalOptions="FillAndExpand"
                  VerticalOptions="FillAndExpand"
                  Drawable="{Binding}"
                  StartInteraction="OnCanvasTouched"/>
                <Image Source="{Binding RobotImageSource}"
                       WidthRequest="30"
                       HeightRequest="30"
                       TranslationX="{Binding RobotX}"
                       TranslationY="{Binding RobotY}"
                       AnchorX="0.5"
                       AnchorY="0.5"
                       Rotation="{Binding RobotAngle}" />   
            </Grid>
            
        </Frame>

        <!-- STATE + CONTROL-->
        <Frame Grid.Row="2"
       Margin="10,0,10,5"
       Padding="8"
       CornerRadius="15"
       HasShadow="True"
       BackgroundColor="#1E1E1E">

            <!-- left = State, middle = charge, right = Controls -->
            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- STATE -->
                <Frame Grid.Column="0"
               Margin="0,0,8,0"
               CornerRadius="10"
               HasShadow="True"
               BackgroundColor="#2E2E2E"
               VerticalOptions="FillAndExpand">


                    <StackLayout Spacing="4"
                         VerticalOptions="FillAndExpand"
                         WidthRequest="200">

                        <Label Text="Robot state"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="White"
                       Margin="0,0,0,5"
                       
                       HorizontalOptions="FillAndExpand"/>
                        <Label Text="{Binding State.X, StringFormat='X: {0:F2}'}" TextColor="White"/>
                        <Label Text="{Binding State.Y, StringFormat='Y: {0:F2}'}" TextColor="White"/>
                        <Label Text="{Binding State.Angle, StringFormat='Angle: {0:F2}'}" TextColor="White"/>
                        <Label Text="{Binding State.DistanceSensor, StringFormat='Distance: {0:F2}'}" TextColor="White"/>
                        <Label Text="{Binding State.SensorDistance, StringFormat='Sensor: {0:F1}'}" TextColor="White"/>
                        <Label Text="{Binding State.CollisionDistance, StringFormat='Collision: {0:F1}'}" TextColor="White"/>
                        <Label Text="{Binding State.Status, StringFormat='Status: {0:F1}'}" TextColor="DarkOrange"/>

                        <!--BoxView HeightRequest="0" VerticalOptions="FillAndExpand" BackgroundColor="Transparent"-->
                    </StackLayout>
                </Frame>

                <Frame Grid.Column="1"
               Padding="10"
               CornerRadius="10"
               HasShadow="True"
               BackgroundColor="#2E2E2E"
               VerticalOptions="FillAndExpand">


                    <StackLayout Spacing="4"
                         VerticalOptions="FillAndExpand">

                        <!-- BATTERY LABEL -->
                        <Label Text="{Binding State.Battery, StringFormat='Battery: {0:F0}%'}"
                        TextColor="White"/>

                        <ProgressBar Progress="{Binding State.Battery, Converter={StaticResource BatteryConverter}}"
                            HeightRequest="20"
                            ProgressColor="{Binding State.Battery, Converter={StaticResource BatteryColorConverter}}"
                            BackgroundColor="#444444"/>

                        <Grid ColumnDefinitions="*,*,*">
                            <Button Text="🔋 Charge Battery"
                                Command="{Binding ChargeCommand}"
                                IsVisible="{Binding IsBatteryEmpty}"
                                BackgroundColor="#444444"
                                TextColor="White"
                                CornerRadius="10"
                                Margin="10,10,10,10"
                                WidthRequest="250"
                                Grid.Column="0"
                                MaximumWidthRequest="200"/>

                            <Button Text="🧪 Self Test"
                                Command="{Binding SelfTestCommand}"
                                BackgroundColor="#444444"
                                TextColor="White"
                                CornerRadius="10"
                                Margin="10,10,10,10"
                                Grid.Column="1"
                                MaximumWidthRequest="200"/>

                            <Button Text="🧹 Clear"
                                Command="{Binding ClearObstaclesCommand}"
                                BackgroundColor="#444444"
                                TextColor="White"
                                CornerRadius="10"
                                Margin="10,10,10,10"
                                Grid.Column="2"
                                MaximumWidthRequest="200"/>
                            
                        </Grid>
                        <Label Text="{Binding CollisionCount, StringFormat='Nuts eaten: {0}'}"
                           TextColor="DarkOrange"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="EndAndExpand"/>

                        

                        <BoxView HeightRequest="0" VerticalOptions="FillAndExpand" BackgroundColor="Transparent"/>
                    </StackLayout>
                </Frame>


                <!-- CONTROL GRID -->
                <Grid Grid.Column="2"
              RowDefinitions="Auto,Auto,Auto"
              ColumnDefinitions="Auto,Auto,Auto"
              Padding="10"
              HorizontalOptions="End"
              VerticalOptions="Center">

                    <Button Grid.Row="0" Grid.Column="1"
                    Text="↑"
                    WidthRequest="50" HeightRequest="50"
                    Style="{StaticResource ControlButtonStyle}"
                    Command="{Binding ForwardCommand}" />

                    <Button Grid.Row="1" Grid.Column="0"
                    Text="↻"
                    WidthRequest="50" HeightRequest="50"
                    Style="{StaticResource ControlButtonStyle}"
                    Command="{Binding RotateRightCommand}" />

                    <Button Grid.Row="1" Grid.Column="2"
                    Text="↺"
                    WidthRequest="50" HeightRequest="50"
                    Style="{StaticResource ControlButtonStyle}"
                    Command="{Binding RotateLeftCommand}" />

                    <Button Grid.Row="2" Grid.Column="1"
                    Text="↓"
                    WidthRequest="50" HeightRequest="50"
                    Style="{StaticResource ControlButtonStyle}"
                    Command="{Binding BackwardCommand}" />

                </Grid>
            </Grid>
        </Frame>
    </Grid>
</ContentPage>
